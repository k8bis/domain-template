# =========================================================
# APPLICATION
# =========================================================
RODELSOFT_ENV=DEV
RODELSOFT_APP=your_app_name
DOMAIN_APP_ID=your_app_id

# =========================================================
# DATABASE (APPLICATION)
# =========================================================
APP_MYSQL_HOST=your_mysql_host
APP_MYSQL_PORT=3306
APP_MYSQL_USER=your_mysql_user
APP_MYSQL_PASSWORD=your_mysql_password
APP_MYSQL_DATABASE=your_database

DB_MAX_RETRIES=30
DB_RETRY_DELAY=2

# =========================================================
# DATABASE CONTRACT (FRAMEWORK)
# =========================================================
RS_MYSQL_HOST=${APP_MYSQL_HOST}
RS_MYSQL_PORT=${APP_MYSQL_PORT}
RS_MYSQL_USER=${APP_MYSQL_USER}
RS_MYSQL_PASSWORD=${APP_MYSQL_PASSWORD}
RS_MYSQL_DATABASE=${APP_MYSQL_DATABASE}

# =========================================================
# CONTROL PLANE
# =========================================================
CONTROL_PLANE_BASE_URL=http://your-control-plane:8088
CONTROL_PLANE_TIMEOUT=3.0
CONTROL_PLANE_READ_TIMEOUT=3.0

# =========================================================
# MEDIA SERVICE
# =========================================================
MEDIA_SERVICE_URL=http://your-media-service:8500

# =========================================================
# SECURITY
# =========================================================
SECRET_KEY=CHANGE_ME_MIN_32_CHARS
ALGORITHM=HS256
INTERNAL_SHARED_SECRET=CHANGE_ME_INTERNAL_SHARED_SECRET

# =========================================================
# APPLICATION ROUTING
# =========================================================
APP_BASE_PATH=/ext/your-app
APP_MENU_URL=/
LOGOUT_REDIRECT_URL=/

# =========================================================
# POLICY RUNTIME
# =========================================================
POLICY_SERVICE_URL=http://policy-service:8600
POLICIES_DIR=/path/to/policies
POLICY_TTL_SECONDS=300

# =========================================================
# FRAMEWORK
# =========================================================
FRAMEWORK_DIR=/path/to/rodelsoft-framework

# =========================================================
# DOCKER
# =========================================================
CONTAINER_NAME=your-container

APP_PORT=8000
APP_IP=172.33.0.10

DOCKER_SUBNET=172.33.0.0/16
DOCKER_EXTERNAL_NETWORK=rodelsoft-admin-core_rodelsoft_net
DOCKER_HOST_GATEWAY_IP=host-gateway

# =========================================================
# MODULE SETTINGS
# =========================================================
# Add here any application-specific configuration.